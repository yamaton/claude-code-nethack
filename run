#!/bin/bash

# --- Configuration ---
SESSION_NAME="claude-nethack"
# Fixed pane size (window-size=manual below), wide enough that NetHack
# renders menus as a side panel past column 80 instead of a popup that
# overwrites map content. Deliberately independent of any attached client's
# terminal size, since tmux's default window-size=latest would otherwise
# resize the pane (and change how NetHack lays out menus) every time a
# viewer with a different terminal width attaches.
SESSION_WIDTH=154
SESSION_HEIGHT=60
NETHACK_OPTIONS_ENV="NETHACKOPTIONS=whatis_coord:m"
NETHACK_COMMAND="nethack -u Claude -p valkyrie -r human"
KEY_DELAY=0.3

# Send input by pasting a buffer into the pane instead of send-keys:
# since tmux 3.7, send-keys is refused with "client is read-only" when the
# only attached client is a read-only viewer (tmux attach -r), while
# paste-buffer goes straight to the pane. Pasting takes literal characters,
# so named keys must be translated.
#
# Escape is the one key that can't go through paste-buffer: tmux mangles a
# lone ESC byte (0x1b) in a pasted buffer into the two-character literal
# text "^[" instead of delivering the real control byte, so NetHack never
# sees an actual Escape keypress. send-keys delivers a genuine ESC, at the
# cost of failing if a read-only client is attached (see above).
send_input() {
    local key="$1" literal
    if [ "$key" = "Escape" ]; then
        tmux send-keys -t "$SESSION_NAME" Escape
        return
    fi
    # Ctrl key combos, written 'C-x' or '^x' (letter, either case). These must
    # use send-keys like Escape above: paste-buffer mangles control bytes into
    # two printable caret-notation characters (0x10 becomes '^' 'P'), so the
    # game never sees the real control byte.
    if [[ "$key" =~ ^(C-|\^)([A-Za-z])$ ]]; then
        tmux send-keys -t "$SESSION_NAME" "C-${BASH_REMATCH[2],,}"
        return
    fi
    case "$key" in
        Space)        literal=' ' ;;
        Enter|Return) literal=$'\r' ;;
        Tab)          literal=$'\t' ;;
        *)            literal="$key" ;;
    esac
    tmux set-buffer -b claude-run-input -- "$literal"
    tmux paste-buffer -d -b claude-run-input -t "$SESSION_NAME"
}


# Show help information
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    cat << 'EOF'
NetHack tmux Interface - Claude Code NetHack Project

USAGE:
    ./run [COMMAND...]           Send commands to NetHack and view current state
    ./run --init                 Start fresh game (kills existing session)
    ./run --cleanup              Kill the tmux session completely
    ./run --help                 Show this help

EXAMPLES:
    ./run                        View current game state
    ./run Escape                 Enter Escape key (to cancel)
    ./run Space                  Enter Space key (to proceed)
    ./run h j                    Move west, then to south
    ./run o h                    Open door to the west
    ./run s                      Search for hidden doors/passages
    ./run ,                      Pick up items
    ./run 5k                     Move north 5 times
    ./run '#quit'                Extended command (Enter is sent automatically)
    ./run '^P'                   Ctrl+P: view message history (C-p also works)

NETHACK SYMBOLS:
    @    Claude's position
    >    Stairs down (goal!)
    <    Stairs up
    #    Corridors
    +    Closed doors
    $    Gold/treasure
    %    Enemy corpses

For more information, see README.md and CLAUDE.md

This tool is designed for Claude Code to autonomously play NetHack.
EOF
    exit 0
fi

# Add session cleanup option
if [ "$1" = "--cleanup" ]; then
    tmux kill-session -t "$SESSION_NAME" 2>/dev/null
    exit 0
fi

# Add session cleanup option
if [ "$1" = "--init" ]; then
    tmux kill-session -t "$SESSION_NAME" 2>/dev/null
    sleep 0.2
    # Without this shift, "--init" stays in "$@" and falls through to the
    # action loop below, which sends it as literal keystrokes to the fresh
    # session: '-' '-' 'i' 'n' 'i' 't'. On the role-selection menu, 't'
    # selects Tourist; mid-game, 'i' opens inventory and 't' triggers throw.
    shift
fi

# --- Session Management ---
# Check if the tmux session exists. If not, create it and start NetHack.
if ! tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Creating a new tmux session: $SESSION_NAME"
    tmux new-session -d -s "$SESSION_NAME" -x "$SESSION_WIDTH" -y "$SESSION_HEIGHT" -e "$NETHACK_OPTIONS_ENV" -- "$NETHACK_COMMAND"
    tmux set-option -t "$SESSION_NAME" window-size manual
    sleep 1 # Give nethack time to load

    # needs this when resuming the game
    send_input Space
fi

# --- Action and State Capture ---

# Loop through each argument provided to the script.
# This allows us to send them one by one with a delay in between.
for arg in "$@"; do
    # Send the current argument (e.g., 'd', then 'a').
    send_input "$arg"
    # Wait for a short moment to let NetHack process the keystroke.
    sleep "$KEY_DELAY"
    # Extended commands (e.g. '#quit') open the "#" prompt and only type the
    # command name; NetHack does not run the command until Enter is pressed.
    if [[ "$arg" == '#'* ]]; then
        send_input Enter
        sleep "$KEY_DELAY"
    fi
done

# Wait a fraction of a second for the screen to update.
sleep 0.2

# Capture the pane's content and format it for LLM consumption.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
tmux capture-pane -p -t "$SESSION_NAME" | python3 "$SCRIPT_DIR/transpose_map.py"
